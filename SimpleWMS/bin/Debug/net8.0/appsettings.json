{
  // Connection string tells EF Core where the SQLite file lives.
  // "Data Source=warehouse.db" means it creates a file called
  // "warehouse.db" right inside the project folder.
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=warehouse.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      // Shows the actual SQL queries EF Core sends — very useful
      // while learning! Set to "Warning" in production.
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",

  // Fix the port so it is always http://localhost:5000
  // This way you never have to guess the port number.
  "Urls": "http://localhost:5000"
}
